# ============================================================
# Python
# ============================================================
venv/
__pycache__/
*.pyc
*.pyo
*.egg-info/
.eggs/
build/
dist/

# ============================================================
# ANCScan runtime data — never commit real scan results, findings,
# or credentials. These are generated locally and are specific to
# whatever network you actually scanned.
# ============================================================
Platform/ancscan.db
Platform/*.db
output/*.pdf
data/*
!data/.gitkeep

# ============================================================
# Secrets — API keys must NEVER be committed. Set these via
# environment variables (see README) or a local .env file that
# stays untracked.
# ============================================================
.env
.env.*
!.env.example

# ============================================================
# Editor / OS noise
# ============================================================
.vscode/
.idea/
*.swp
.DS_Store

# ============================================================
# Misc project files not meant for the public repo
# ============================================================
Platform/app.py.save
Important\ infos.txt
team\ meeting\ notes.txt
